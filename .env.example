# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# GitHub Models API Configuration
# Get your token from: https://github.com/settings/tokens (needs 'models:read' scope)
GITHUB_TOKEN=your_github_token_here

# Optional: Default GitHub Model (default: openai/gpt-4.1)
# Available models: openai/gpt-4.1, openai/gpt-4o, anthropic/claude-3.5-sonnet, meta/llama-3.3-70b-instruct
# GITHUB_MODEL=openai/gpt-4.1

# Optional: Custom OpenAI base URL (for Azure or other providers)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Debug mode
# DEBUG=true
