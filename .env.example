# OpenAI API Configuration (for LLM generation, NOT embeddings)
OPENAI_BASE_URL=https://api.openai.com/v1(or https://models.github.ai/inference)
OPENAI_API_KEY=your_openai_api_key_here
GITHUB_MODEL=openai/gpt-4.1

# GitHub Models API Configuration
# Get your token from: https://github.com/settings/tokens (needs 'models:read' scope)
#GITHUB_TOKEN=your_github_token_here

# Optional: Default GitHub Model (default: openai/gpt-4.1)
# Available models: openai/gpt-4.1, openai/gpt-4o, anthropic/claude-3.5-sonnet, meta/llama-3.3-70b-instruct
# GITHUB_MODEL=openai/gpt-4.1

# Embedding Model Configuration (local, no API needed)
# Default: all-MiniLM-L6-v2 (fast, 384 dim)
# Alternative: all-mpnet-base-v2 (better, 768 dim)
#EMBEDDING_MODEL=../all-MiniLM-L6-v2

# For air-gapped/offline servers: set local model path
# Download model from HuggingFace on another machine, then transfer
EMBEDDING_MODEL_PATH=../all-MiniLM-L6-v2

# Optional: Custom OpenAI base URL (for Azure or other providers)
# OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# Rerank（默认 BGE 本地，不占 GitHub 配额）
# =============================================================================
#RERANK_BACKEND=bge
#BGE_RERANKER_MODEL=BAAI/bge-reranker-base
# 离线或已下载到数据盘时填写绝对路径（与 BGE_RERANKER_MODEL 二选一为主）
BGE_RERANKER_PATH=../bge-reranker-base
BGE_RERANKER_DEVICE=cpu
BGE_RERANKER_QUERY_CHARS=512
BGE_RERANKER_PASSAGE_CHARS=2000
BGE_RERANKER_PREDICT_BATCH=16
# 若改回远程 LLM rerank：RERANK_BACKEND=llm，并保证上面有 GITHUB_TOKEN 或 OPENAI_API_KEY
# RERANK_BACKEND=llm
# RERANK_MAX_RETRIES=3
# RERANK_RETRY_BASE_SEC=2.0
# RERANK_BATCH_DELAY_SEC=1.5
# RERANK_QUERY_MAX_CHARS=512
# RERANK_PASSAGE_MAX_CHARS=600
# RERANK_BATCH_SIZE=6
# 完全不 rerank，只用向量分数排序
# RERANK_BACKEND=none
# =============================================================================
# 生成答案时的上下文长度上限（避免超长上下文导致 JSON 失败）
# =============================================================================
RAG_ANSWER_MAX_CHARS_PER_PAGE=8000
RAG_ANSWER_MAX_CONTEXT_CHARS=45000
# =============================================================================
# 解释类答案里若模型仍写 N/A，可再收紧（可选）
# =============================================================================
# RERANK_PASSAGE_MAX_CHARS=600
# RERANK_QUERY_MAX_CHARS=512

# Optional: Debug mode
# DEBUG=true
